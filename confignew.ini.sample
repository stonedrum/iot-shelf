# MQTT Handler 配置文件示例
# 复制为 confignew.ini 后填写实际值:
#   cp confignew.ini.sample confignew.ini

# 数据库配置
[database]
host = your-mysql-host.example.com
port = 3306
user = your_db_user
password = your_db_password
name = aishelf

# MQTT配置
[mqtt]
broker = your-mqtt-broker.example.com
port = 1883
user = your_mqtt_user
password = your_mqtt_password
topic = ZHZN/JSLS001
# 每个运行实例需使用唯一 client_id，避免多实例互相踢下线
client_id = water_shelf_mqtt_handler_001

# 应用配置
[app]
app_name = AIShelf
app_version = 1.0.0
debug = True

# 安全配置
[security]
secret_key = change-me-to-a-random-secret-key
algorithm = HS256
access_token_expire_minutes = 30

# 邮件配置（163 邮箱需使用 SMTP 授权码，非登录密码）
[email]
smtp_host = smtp.163.com
smtp_port = 465
smtp_user = your_email@163.com
smtp_password = your_smtp_authorization_code
sender_name = 搬夫科技
